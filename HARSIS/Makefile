harsis_qt.app/Contents/PkgInfo: 
	@test -d harsis_qt.app/Contents || mkdir -p harsis_qt.app/Contents
	@$(DEL_FILE) harsis_qt.app/Contents/PkgInfo
	@echo "APPL????" > harsis_qt.app/Contents/PkgInfo
harsis_qt.app/Contents/Info.plist: 
	@test -d harsis_qt.app/Contents || mkdir -p harsis_qt.app/Contents
	@$(DEL_FILE) harsis_qt.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - /opt/homebrew/share/qt/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,batu.harsis-qt,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},batu.harsis-qt,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},11.0,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,harsis_qt,g" -e "s,@LIBRARY@,harsis_qt,g" -e "s,\$${EXECUTABLE_NAME},harsis_qt,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >harsis_qt.app/Contents/Info.plist

